DOMAIN=example.com
ACME_EMAIL=admin@example.com

# Shared Netcup credentials. Keep the real values out of Git.
NETCUP_CUSTOMER_NUMBER=123456
NETCUP_API_KEY=replace-me
NETCUP_API_PASSWORD=replace-me

# DDNS target. Create these A records once in Netcup. The updater keeps their
# destination set to your current public IPv4. Leave NETCUP_DDNS_DOMAIN empty
# to use DOMAIN.
NETCUP_DDNS_DOMAIN=example.com
NETCUP_DDNS_HOSTS=@,*
NETCUP_DDNS_INTERVAL=300s
PUBLIC_IP_URL=https://api64.ipify.org

# Caddy UI
CADDY_UI_USERNAME=admin
CADDY_UI_PASSWORD=change-me
CADDY_ADMIN_URL=http://caddy:2019
CADDYFILE_PATH=/etc/caddy/Caddyfile
CADDY_ROUTES_DIR=/etc/caddy/routes
CADDY_DATA_PATH=/data
CADDY_AUTO_RELOAD=true
